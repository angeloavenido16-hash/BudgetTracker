# ── Database ────────────────────────────────────────────────────
# Local dev (docker-compose Postgres). On Railway this is auto-injected.
DATABASE_URL=postgresql+asyncpg://budget:budget@localhost:5432/budget_tracker

# ── Auth (single user) ──────────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080          # 7 days

# The single app user (password is hashed at startup)
APP_USERNAME=admin
APP_PASSWORD=change-me

# ── CORS ────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:5173
