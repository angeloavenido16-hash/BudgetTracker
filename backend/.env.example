# ── Database ────────────────────────────────────────────────────
# Local dev defaults to SQLite (no server needed). For Postgres use:
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
# On Railway this is auto-injected by the Postgres plugin.
DATABASE_URL=sqlite+aiosqlite:///./budget_tracker.db

# ── Auth (single user) ──────────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080          # 7 days

# The single app user (password is hashed at startup)
# Optional: override the bootstrap admin credentials (used only when DB is empty)
# SEED_USERNAME=admin
# SEED_PASSWORD=admin

# ── CORS ────────────────────────────────────────────────────────
# In Railway, set this to the frontend URL (e.g. https://myapp.up.railway.app).
FRONTEND_ORIGIN=http://localhost:5173
