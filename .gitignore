# ── Secrets / env ───────────────────────────────────────────────────────────
.env
*.env
!*.env.example

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
